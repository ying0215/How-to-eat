EXPO_PUBLIC_GOOGLE_MAPS_SCHEME=comgooglemaps://

# Google Places API — 附近餐廳搜尋
# 請至 https://console.cloud.google.com/apis/credentials 建立 API Key
# 並啟用 Places API (New)
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=

# Google Drive Sync — 雲端同步用的 OAuth Client ID
# Web Application 類型（用於 Web 平台）
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_CLIENT_SECRET=

# Android OAuth Client ID（Android 類型，用於 APK 建置）
# 在 Google Cloud Console 建立 Android 類型的 OAuth Client ID
# 需填入 package name + SHA-1 簽名指紋
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
